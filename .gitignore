# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# Playwright
playwright-report/
playwright/.cache/
test-results/

# Screenshots (keep directory, ignore files)
e2e/screenshots/*.png
!e2e/screenshots/.gitkeep

# generated native folders
/ios
/android
!/.android
e2e/screenshot.spec.ts-snapshots/

# Qt migration native sources (keep these!)
!/plugins/native

